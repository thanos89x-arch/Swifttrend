# ── SwiftTrend AI · Production Environment Variables ──────────────────
# Copy to .env.production and fill in real values.
# NEVER commit the real .env.production file.
# All VITE_ vars are bundled into the client — keep them non-secret.

# ── Public (inlined by Vite at build time) ─────────────────────────────

# Base URL of your Edge proxy (same origin in production, or custom domain)
VITE_API_BASE=/api

# Optional: override Anthropic endpoint (leave blank to use /api/anthropic)
VITE_ANTHROPIC_ENDPOINT=

# Optional: Force demo mode in production build (true/false)
VITE_DEMO_MODE=false

# ── Runtime secrets (injected by hosting platform — NEVER prefixed VITE_) ─

# Anthropic API key → set in Vercel / Netlify / Cloudflare env UI
# CI secret name: ANTHROPIC_KEY
ANTHROPIC_KEY={{ANTHROPIC_KEY}}

# FTMO challenge backend URL + auth token
FTMO_API_URL={{FTMO_API_URL}}
FTMO_API_KEY={{FTMO_API_KEY}}

# Twelve Data / market data provider API key
MARKET_DATA_KEY={{MARKET_DATA_KEY}}

# Production domain (used for CORS allow-list in edge proxy)
PRODUCTION_DOMAIN={{PRODUCTION_DOMAIN}}

# ── CI / Deploy tokens (only needed in GitHub Actions secrets) ──────────
# VERCEL_TOKEN        → Vercel personal access token
# VERCEL_ORG_ID       → Vercel org/team ID
# VERCEL_PROJECT_ID   → Vercel project ID
# NETLIFY_AUTH_TOKEN  → Netlify personal access token
# NETLIFY_SITE_ID     → Netlify site ID
# CF_API_TOKEN        → Cloudflare API token (Workers deploy scope)
# CF_ACCOUNT_ID       → Cloudflare account ID
